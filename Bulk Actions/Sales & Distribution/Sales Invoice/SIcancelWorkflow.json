    {
      "id": "code_node_CtfkSP3q",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Map Latest SO/GD list",
        "isValidator": true,
        "nodeName": "Map Latest SO/GD list",
        "name": "Map Latest SO/GD list",
        "script": {
          "type": "javascript",
          "code": "const data = {{node:get_node_FPExdl9O.data.data}};\nconst soList = {{node:search_node_V3rnGDPj.data.data}} || [];\nconst gdList = {{node:search_node_Gvy1Uni8.data.data}} || [];\n\n\nconst roundTo3 = (value) => {\n  return Math.round((parseFloat(value) || 0) * 1000) / 1000;\n};\n\nconst formatNumber = (value) => {\n  if (value === null || value === undefined || value === \"\") return \"0.0000\";\n  return parseFloat(value).toFixed(3);\n};\n\n\nconst updateGoodsDelivery = (gdIds, tableSi) => {\n  let gdUpdatedList = [];\n  for(const gdID of gdIds) {\n    const gdData = gdList.find(gd => gd.id === gdID) || [];\n    const gdItems = gdData?.table_gd || [];\n\n    // Process GR items\n    const { updatedItems, newSIStatus } = processItems(\n      gdItems,\n      tableSi,\n      gdData.id,\n      \"line_gd_id\",\n      \"gd_line_id\",\n      \"gd_qty\",\n    );\n\n    gdUpdatedList.push({\n      gd_id: gdData.id,\n      si_status: newSIStatus,\n      table_gd: updatedItems\n    })\n  }\n\n  return gdUpdatedList;\n};\n\nconst updateSalesOrder = (soIds, tableSi) => {\n  let soUpdatedList = [];\n  for(const soID of soIds) {\n    const soData = soList.find(so => so.id === soID)\n    const soItems = soData.table_so || [];\n\n    const { updatedItems, newSIStatus } = processItems(\n      soItems,\n      tableSi,\n      soData.id,\n      \"line_so_id\",\n      \"so_line_id\",\n      \"so_quantity\",\n    );\n\n    soUpdatedList.push({\n      so_id: soData.id,\n      si_status: newSIStatus,\n      table_so: updatedItems\n    })\n  }\n\n  return soUpdatedList;\n};\n\nconst processItems = (items, tableSi, docId, docIdKey, siLineIdKey, qtyKey) => {\n  // Filter SI items for the current document\n  const filteredSI = tableSi.filter((item) => item[docIdKey] === docId);\n\n  // Initialize tracking\n  let totalItems = items.length;\n  \n  // Update items using find() with id matching\n  const updatedItems = items.map((item) => {\n    const matchedSI = filteredSI.find(si => si[siLineIdKey] === item.id);\n    \n    if (matchedSI) {\n      const siInvoicedQty = roundTo3(matchedSI.invoice_qty);\n      const currentInvoicedQty = roundTo3(item.invoice_qty);\n      const totalInvoicedQty = roundTo3(currentInvoicedQty - siInvoicedQty);\n      const currentPostedQty = roundTo3(item.posted_qty);\n      const totalPostedQty = roundTo3(currentPostedQty - siInvoicedQty);\n      \n      const updatedItem = {\n        ...item,\n        invoice_qty: totalInvoicedQty,\n        posted_qty: totalPostedQty\n      };\n      \n      if (roundTo3(updatedItem.invoice_qty) > 0) {\n          updatedItem.si_status = \"Partially Invoiced\";\n          if (roundTo3(updatedItem.invoice_qty) >= roundTo3(item[qtyKey] || 0)) {\n            updatedItem.si_status = \"Fully Invoiced\";\n          }\n      } else {\n        updatedItem.si_status = null;\n      }\n      \n      return updatedItem;\n    }\n    \n    return { ...item };\n  });\n\n  // Determine new SI status\n  let partiallyInvoicedItems = updatedItems.filter(item => item.si_status === \"Partially Invoiced\").length;\n  let fullyInvoicedItems = updatedItems.filter(item => item.si_status === \"Fully Invoiced\").length;\n  const allItemsComplete = fullyInvoicedItems === totalItems;\n  const anyItemProcessing = partiallyInvoicedItems > 0 || fullyInvoicedItems > 0;\n  let newSIStatus = anyItemProcessing\n    ? allItemsComplete\n      ? \"Fully Invoiced\"\n      : \"Partially Invoiced\"\n    : \"\";\n\n  return { updatedItems, newSIStatus };\n};\n\nconst soIds = Array.isArray(data.so_id) ? data.so_id : [data.so_id];\nlet updatedGD = [];\nif (data.gd_id.length > 0) {\n  const gdIds = Array.isArray(data.gd_id) ? data.gd_id : [data.gd_id];\n  const updatedGDData = updateGoodsDelivery(gdIds, data.table_si);\n  updatedGD = updatedGDData\n}\n\nconst updatedSO = updateSalesOrder(soIds, data.table_si);\n\nreturn {\n  updatedGD, \n  updatedSO,\n  updatedSI: {\n    id: data.id,\n    si_status: \"Cancelled\",\n    sales_invoice_no: data.sales_invoice_no + \"-Cancelled\",\n  }\n}"
        },
