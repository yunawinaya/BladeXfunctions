    {
      "id": "code_classify",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Classify",
        "isValidator": true,
        "nodeName": "Classify",
        "name": "Classify",
        "script": {
          "type": "javascript",
          "code": "const gdList = {{node:search_gd.data.data}} || [];\nconst ppList = {{node:search_pp.data.data}} || [];\nconst siList = {{node:search_si.data.data}} || [];\n\nconst createdGd = gdList.filter((d) => d.gd_status === \"Created\");\nconst createdPp = ppList.filter((d) => d.to_status === \"Created\");\nconst draftGd = gdList.filter((d) => d.gd_status === \"Draft\");\nconst draftPp = ppList.filter((d) => d.to_status === \"Draft\");\nconst invoiced = siList.filter((s) => s.si_status !== \"Draft\" && s.si_status !== \"Cancelled\");\nconst draftSI = siList.filter((s) => s.si_status === \"Draft\");\n\nlet code = \"200\";\nlet message = \"\";\nif (createdGd.length > 0 || createdPp.length > 0) {\n  code = \"400\";\n  message = \"Has a created \" + (createdPp.length > 0 ? \"picking plan\" : \"goods delivery\") + \". Cancel it first.\";\n} else if (invoiced.length > 0) {\n  code = \"400\";\n  message = \"Sales order is already invoiced. Cannot cancel.\";\n}\n\nreturn {\n  code: code,\n  message: message,\n  deleteGD: (draftGd.length > 0 && code === \"200\") ? 1 : 0,\n  deletePP: (draftPp.length > 0 && code === \"200\") ? 1 : 0,\n  deleteSI: (draftSI.length > 0 && code === \"200\") ? 1 : 0,\n  draftGdIds: draftGd.map((d) => d.id),\n  draftPpIds: draftPp.map((d) => d.id),\n  draftSiIds: draftSI.map((s) => s.id)\n};"
        },
        "response_json": [
