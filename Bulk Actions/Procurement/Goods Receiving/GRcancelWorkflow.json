    {
      "id": "code_reversals",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Compute PO Reversals",
        "isValidator": true,
        "nodeName": "Compute PO Reversals",
        "name": "Compute PO Reversals",
        "script": {
          "type": "javascript",
          "code": "const grRaw = {{node:get_gr.data.data}};\nconst gr = Array.isArray(grRaw) ? grRaw[0] : grRaw;\nconst poList = {{node:search_po.data.data}} || [];\nconst grLines = (gr && gr.table_gr) ? gr.table_gr : [];\nconst grNo = {{workflowparams:gr_no}} || \"\";\n\n// Total qty to reverse per PO line item.\nconst reversals = {};\nfor (const line of grLines) {\n  // Split-parent rows sum their children; counting them would double-reverse.\n  if (line.is_split === \"Yes\" && line.parent_or_child === \"Parent\") {\n    continue;\n  }\n  const lineId = line.po_line_item_id;\n  reversals[lineId] = (reversals[lineId] || 0) + parseFloat(line.received_qty || 0);\n}\n\nconst poUpdates = poList.map((po) => {\n  const items = (po.table_po || []).map((l) => {\n    const rev = reversals[l.id] || 0;\n    if (rev > 0) {\n      const cur = parseFloat(l.created_received_qty || 0);\n      // toFixed STRING: raw float output breaks the DB multipleOf check.\n      return Object.assign({}, l, { created_received_qty: Math.max(0, cur - rev).toFixed(3) });\n    }\n    return Object.assign({}, l);\n  });\n\n  const hasRemainingCreated = items.some((i) => (parseFloat(i.created_received_qty) || 0) > 0);\n  const allCompleted = items.every((i) => (parseFloat(i.received_qty) || 0) >= (parseFloat(i.quantity) || 0));\n  const anyProcessing = items.some((i) => (parseFloat(i.received_qty) || 0) > 0 && (parseFloat(i.received_qty) || 0) < (parseFloat(i.quantity) || 0));\n\n  let grStatus;\n  if (hasRemainingCreated) {\n    grStatus = \"Created\";\n  } else if (allCompleted) {\n    grStatus = \"Fully Received\";\n  } else if (anyProcessing) {\n    grStatus = \"Partially Received\";\n  } else {\n    grStatus = \"Cancelled\";\n  }\n\n  return { po_id: po.id, table_po: items, gr_status: grStatus };\n});\n\nreturn {\n  poUpdates: poUpdates,\n  cancelledGrNo: grNo.endsWith(\"-Cancelled\") ? grNo : grNo + \"-Cancelled\"\n};"
        },
        "response_json": [
