    {
      "id": "code_map_cancel",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Map Latest PO/GR",
        "isValidator": true,
        "nodeName": "Map Latest PO/GR",
        "name": "Map Latest PO/GR",
        "script": {
          "type": "javascript",
          "code": "const data = {{node:get_pi_data.data.data}};\nconst poList = {{node:search_po_list.data.data}} || [];\nconst grList = {{node:search_gr_list.data.data}} || [];\n\nconst roundTo3 = (value) => Math.round((parseFloat(value) || 0) * 1000) / 1000;\n\nconst processItems = (items, tablePi, docId, docIdKey, piLineIdKey, qtyKey, reversePosted) => {\n  const filteredPI = tablePi.filter((item) => item[docIdKey] === docId);\n\n  const updatedItems = items.map((item) => {\n    const matchedPI = filteredPI.find((pi) => pi[piLineIdKey] === item.id);\n    if (!matchedPI) return { ...item };\n\n    const piQty = roundTo3(matchedPI.invoice_qty);\n    const newInvoiceQty = Math.max(0, roundTo3(roundTo3(item.invoice_qty) - piQty));\n    const updatedItem = { ...item, invoice_qty: newInvoiceQty };\n\n    if (reversePosted) {\n      updatedItem.posted_qty = Math.max(0, roundTo3(roundTo3(item.posted_qty) - piQty));\n    }\n\n    if (newInvoiceQty > 0) {\n      updatedItem.pi_status = \"Partially Invoiced\";\n      if (newInvoiceQty >= roundTo3(item[qtyKey] || 0)) {\n        updatedItem.pi_status = \"Fully Invoiced\";\n      }\n    } else {\n      updatedItem.pi_status = null;\n    }\n\n    return updatedItem;\n  });\n\n  const countableItems = updatedItems.filter((item) => item.parent_or_child !== \"Child\");\n  const totalItems = countableItems.length;\n  const partiallyInvoicedItems = countableItems.filter((item) => item.pi_status === \"Partially Invoiced\").length;\n  const fullyInvoicedItems = countableItems.filter((item) => item.pi_status === \"Fully Invoiced\").length;\n\n  const allItemsComplete = fullyInvoicedItems === totalItems;\n  const anyItemProcessing = partiallyInvoicedItems > 0 || fullyInvoicedItems > 0;\n  const newPIStatus = anyItemProcessing\n    ? allItemsComplete\n      ? \"Fully Invoiced\"\n      : \"Partially Invoiced\"\n    : \"\";\n\n  return { updatedItems, newPIStatus };\n};\n\nconst poIds = Array.isArray(data.po_id) ? data.po_id : [data.po_id];\nlet updatedPO = [];\nfor (const poID of poIds) {\n  const poData = poList.find((po) => po.id === poID);\n  if (!poData) continue;\n  const poItems = poData.table_po || [];\n  const { updatedItems, newPIStatus } = processItems(poItems, data.table_pi, poData.id, \"line_po_id\", \"po_line_id\", \"quantity\", true);\n  updatedPO.push({ po_id: poData.id, pi_status: newPIStatus, table_po: updatedItems });\n}\n\nlet updatedGR = [];\nif (data.gr_id && data.gr_id.length > 0) {\n  const grIds = Array.isArray(data.gr_id) ? data.gr_id : [data.gr_id];\n  for (const grID of grIds) {\n    const grData = grList.find((gr) => gr.id === grID);\n    if (!grData) continue;\n    const grItems = grData.table_gr || [];\n    const { updatedItems, newPIStatus } = processItems(grItems, data.table_pi, grData.id, \"line_gr_id\", \"gr_line_id\", \"received_qty\", false);\n    updatedGR.push({ gr_id: grData.id, pi_status: newPIStatus, table_gr: updatedItems });\n  }\n}\n\nreturn {\n  updatedPO,\n  updatedGR,\n  updatedPI: {\n    id: data.id,\n    pi_status: \"Cancelled\",\n    purchase_invoice_no: data.purchase_invoice_no + \"-Cancelled\"\n  }\n};"
        },
