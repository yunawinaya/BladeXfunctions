    {
      "id": "code_classify",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Classify",
        "isValidator": true,
        "nodeName": "Classify",
        "name": "Classify",
        "script": {
          "type": "javascript",
          "code": "const grList = {{node:search_gr.data.data}} || [];\nconst piList = {{node:search_pi.data.data}} || [];\nconst cancelCreatedGR = {{workflowparams:cancelCreatedGR}};\n\nconst createdGr = grList.filter((g) => g.gr_status === \"Created\");\nconst processedGr = grList.filter((g) => g.gr_status === \"Received\" || g.gr_status === \"Completed\");\nconst draftGr = grList.filter((g) => g.gr_status === \"Draft\");\nconst invoicedPi = piList.filter((p) => p.pi_status !== \"Draft\" && p.pi_status !== \"Cancelled\");\nconst draftPi = piList.filter((p) => p.pi_status === \"Draft\");\n\nlet code = \"200\";\nlet message = \"\";\nif (processedGr.length > 0) {\n  // Hard block: stock already received.\n  code = \"400\";\n  message = \"Has received/completed goods receiving. Cannot cancel.\";\n} else if (invoicedPi.length > 0) {\n  code = \"400\";\n  message = \"Purchase order is already invoiced. Cannot cancel.\";\n} else if (createdGr.length > 0 && cancelCreatedGR != 1) {\n  // Soft block: caller must confirm cascading the GR cancellation.\n  code = \"409\";\n  message = \"Has created goods receiving.\";\n}\n\nconst proceed = code === \"200\";\n\nreturn {\n  code: code,\n  message: message,\n  blocked: proceed ? 0 : 1,\n  grNos: createdGr.map((g) => g.gr_no).join(\", \"),\n  createdGrList: proceed ? createdGr.map((g) => ({ gr_id: g.id, gr_no: g.gr_no, po_id: g.po_id })) : [],\n  deleteGR: (draftGr.length > 0 && proceed) ? 1 : 0,\n  deletePI: (draftPi.length > 0 && proceed) ? 1 : 0,\n  draftGrIds: draftGr.map((g) => g.id),\n  draftPiIds: draftPi.map((p) => p.id)\n};"
        },
        "response_json": [
          { "key": "wf_code", "name": "code", "title": "code", "description": "", "bsonType": "string", "isExpand": false },
          { "key": "wf_message", "name": "message", "title": "message", "description": "", "bsonType": "string", "isExpand": false },
          { "key": "wf_blocked", "name": "blocked", "title": "blocked", "description": "", "bsonType": "number", "isExpand": false },
          { "key": "wf_grnos", "name": "grNos", "title": "grNos", "description": "", "bsonType": "string", "isExpand": false },
          { "key": "wf_createdgrlist", "name": "createdGrList", "title": "createdGrList", "description": "", "bsonType": "any", "isExpand": false, "children": [] },
          { "key": "wf_deletegr", "name": "deleteGR", "title": "deleteGR", "description": "", "bsonType": "number", "isExpand": false },
          { "key": "wf_deletepi", "name": "deletePI", "title": "deletePI", "description": "", "bsonType": "number", "isExpand": false },
          {
            "key": "wf_draftgrids",
            "name": "draftGrIds",
            "title": "draftGrIds",
            "description": "",
            "bsonType": "array",
            "isExpand": true,
            "children": [
              { "key": "wf_draftgrids_item", "name": "items", "title": "", "description": "", "bsonType": "string", "isExpand": false, "isArrayItem": true }
            ]
          },
          {
            "key": "wf_draftpiids",
            "name": "draftPiIds",
            "title": "draftPiIds",
            "description": "",
            "bsonType": "array",
            "isExpand": true,
            "children": [
              { "key": "wf_draftpiids_item", "name": "items", "title": "", "description": "", "bsonType": "string", "isExpand": false, "isArrayItem": true }
            ]
