    {
      "id": "code_classify",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Classify",
        "isValidator": true,
        "nodeName": "Classify",
        "name": "Classify",
        "script": {
          "type": "javascript",
          "code": "const action = {{workflowparams:action}};\n\nlet raw = {{node:get_prt.data.data}};\nif (Array.isArray(raw)) raw = raw[0];\nconst prt = raw || null;\n\nconst isDelete = action === \"delete\" ? 1 : 0;\n\nlet blocked = 0;\nlet code = \"200\";\nlet message = \"\";\n\nconst status = prt ? prt.purchase_return_status : null;\n\nif (!prt) {\n  blocked = 1;\n  code = \"400\";\n  message = \"Purchase return not found.\";\n} else if (isDelete === 1) {\n  // A Created purchase return still holds a created_return_qty reservation on the\n  // GR and PO lines. Deleting it outright would strand that quantity, so it must\n  // be cancelled first.\n  if (status !== \"Draft\" && status !== \"Cancelled\") {\n    blocked = 1;\n    code = \"400\";\n    message =\n      status === \"Created\"\n        ? \"Cancel this purchase return before deleting it.\"\n        : \"Only draft or cancelled purchase returns can be deleted.\";\n  }\n} else if (status !== \"Created\") {\n  blocked = 1;\n  code = \"400\";\n  message =\n    status === \"Completed\"\n      ? \"A completed purchase return cannot be cancelled; its stock has already been returned.\"\n      : \"Only created purchase returns can be cancelled.\";\n}\n\nconst lines = prt && Array.isArray(prt.table_prt) ? prt.table_prt : [];\nconst uniq = (key) => [...new Set(lines.map((l) => l[key]).filter((x) => x))];\n\n// A sentinel keeps the equalAny filter well-formed when a purchase return has no\n// linked GR or PO lines; it matches nothing.\nconst orNone = (arr) => (arr.length > 0 ? arr : [\"__none__\"]);\n\nconst prtNo = (prt && prt.purchase_return_no) || \"\";\n\nreturn {\n  blocked: blocked,\n  code: code,\n  message: message,\n  isDelete: isDelete,\n  prtLines: lines,\n  grIds: orNone(uniq(\"gr_id\")),\n  poLineIds: orNone(uniq(\"po_line_id\")),\n  cancelledPrtNo: prtNo.endsWith(\"-Cancelled\") ? prtNo : prtNo + \"-Cancelled\",\n};"
        },
