    {
      "id": "code_reversals",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Compute Reversals",
        "isValidator": true,
        "nodeName": "Compute Reversals",
        "name": "Compute Reversals",
        "script": {
          "type": "javascript",
          "code": "const roundQty = (v) => parseFloat(parseFloat(v || 0).toFixed(3));\nconst asStr = (v) => Math.max(0, roundQty(v)).toFixed(3);\n\nconst prtLines = {{node:code_classify.data.prtLines}} || [];\n\nlet grHeads = {{node:search_grHeads.data.data}} || [];\nif (!Array.isArray(grHeads)) grHeads = [grHeads];\nlet poLines = {{node:search_poLines.data.data}} || [];\nif (!Array.isArray(poLines)) poLines = [poLines];\n\n// Only a Created purchase return reaches here, so everything it booked sits in\n// created_return_qty. return_quantity is never touched by a cancel.\nconst aggregate = (rows, key) => {\n  const m = {};\n  for (const r of rows || []) {\n    const k = r[key];\n    if (!k) continue;\n    m[k] = roundQty((m[k] || 0) + parseFloat(r.return_quantity || 0));\n  }\n  return m;\n};\n\nconst revByGrLine = aggregate(prtLines, \"gr_line_id\");\nconst revByPoLine = aggregate(prtLines, \"po_line_id\");\n\nconst poLineUpdates = [];\nfor (const line of poLines) {\n  const cur = roundQty(line.created_return_qty);\n  const next = Math.max(0, roundQty(cur - (revByPoLine[line.id] || 0)));\n  if (next === cur) continue;\n  poLineUpdates.push({ id: line.id, created_return_qty: asStr(next) });\n}\n\nconst grUpdates = [];\nfor (const gr of grHeads) {\n  const items = (gr.table_gr || []).map((it) => ({ ...it }));\n  let changed = false;\n  for (const it of items) {\n    const cur = roundQty(it.created_return_qty);\n    const next = Math.max(0, roundQty(cur - (revByGrLine[it.id] || 0)));\n    if (next !== cur) changed = true;\n    it.created_return_qty = asStr(next);\n  }\n\n  // Same idempotent rule as code_node_syncCalc in PRTsaveWorkflow.\n  // Split children are per-bin detail; only parent/regular rows are returnable, and\n  // PRT lines only ever target those. Counting children would make \"Fully Returned\"\n  // unreachable for any split goods receiving.\n  const returnable = items.filter((it) => it.parent_or_child !== \"Child\");\n\n  let fully = 0;\n  let partially = 0;\n  let reserved = 0;\n  for (const it of returnable) {\n    const rq = parseFloat(it.return_quantity || 0);\n    const cq = parseFloat(it.created_return_qty || 0);\n    if (rq > 0) {\n      partially++;\n      if (rq >= parseFloat(it.received_qty || 0)) fully++;\n    }\n    if (cq > 0) reserved++;\n  }\n  let status = \"\";\n  if (returnable.length > 0 && fully === returnable.length) status = \"Fully Returned\";\n  else if (partially > 0) status = \"Partially Returned\";\n  else if (reserved > 0) status = \"Created\";\n\n  if (!changed && status === (gr.return_status || \"\")) continue;\n  grUpdates.push({ id: gr.id, table_gr: items, return_status: status });\n}\n\nreturn {\n  poLineUpdates: poLineUpdates,\n  grUpdates: grUpdates,\n  hasPoUpdates: poLineUpdates.length > 0 ? 1 : 0,\n  hasGrUpdates: grUpdates.length > 0 ? 1 : 0,\n};"
        },
