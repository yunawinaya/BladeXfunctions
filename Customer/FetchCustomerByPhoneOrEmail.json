    {
      "id": "code_node_yrSiOiir",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Determine Params",
        "isValidator": true,
        "nodeName": "Determine Params",
        "name": "Determine Params",
        "script": {
          "type": "javascript",
          "code": "const mobile = {{workflowparams:mobile_number}};\nconst mobileStr = (mobile == null ? \"\" : String(mobile)).trim();\nconst lookupBy = mobileStr ? \"phone\" : \"email\";\n\n// SE Asia mobile patterns (national subscriber portion only, no leading 0 / CC).\n// Add countries here: { cc, nationalRe, hasNationalZero }.\nconst COUNTRIES = [\n  { cc: \"60\", nationalRe: /^1\\d{8,9}$/, hasNationalZero: true },\n  { cc: \"65\", nationalRe: /^[89]\\d{7}$/, hasNationalZero: false },\n  { cc: \"66\", nationalRe: /^[689]\\d{8}$/, hasNationalZero: true },\n  { cc: \"62\", nationalRe: /^8\\d{8,11}$/, hasNationalZero: true }\n];\n\nconst detectCountries = (s) => {\n  if (!s) return [];\n  const sorted = COUNTRIES.slice().sort((a, b) => b.cc.length - a.cc.length);\n  const out = [];\n  if (s.startsWith(\"+\")) {\n    const digits = s.slice(1);\n    for (const c of sorted) {\n      if (digits.startsWith(c.cc) && c.nationalRe.test(digits.slice(c.cc.length))) {\n        out.push({ cc: c.cc, national: digits.slice(c.cc.length) });\n      }\n    }\n    return out;\n  }\n  for (const c of sorted) {\n    if (s.startsWith(c.cc) && c.nationalRe.test(s.slice(c.cc.length))) {\n      out.push({ cc: c.cc, national: s.slice(c.cc.length) });\n    }\n  }\n  if (out.length > 0) return out;\n  if (s.startsWith(\"0\")) {\n    const candidate = s.slice(1);\n    for (const c of sorted) {\n      if (c.hasNationalZero && c.nationalRe.test(candidate)) {\n        out.push({ cc: c.cc, national: candidate });\n      }\n    }\n  } else {\n    for (const c of sorted) {\n      if (!c.hasNationalZero && c.nationalRe.test(s)) {\n        out.push({ cc: c.cc, national: s });\n      }\n    }\n  }\n  return out;\n};\n\nconst variants = new Set();\nif (mobileStr) {\n  variants.add(mobileStr);\n  const stripped = mobileStr.startsWith(\"+\") ? mobileStr.slice(1) : mobileStr;\n  variants.add(stripped);\n  const candidates = detectCountries(mobileStr);\n  for (const c of candidates) {\n    variants.add(c.cc + c.national);\n    variants.add(\"+\" + c.cc + c.national);\n    const meta = COUNTRIES.find(x => x.cc === c.cc);\n    if (meta && meta.hasNationalZero) variants.add(\"0\" + c.national);\n  }\n}\nconst mobileVariants = Array.from(variants);\n\nreturn { lookupBy, mobileVariants };"
        },
