    {
      "id": "code_node_hrParseSnap",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Parse Snapshot",
        "isValidator": true,
        "nodeName": "Parse Snapshot",
        "name": "Parse Snapshot",
        "script": {
          "type": "javascript",
          "code": "// search-node returns data.data as an array (possibly empty).\nconst raw = {{node:search_node_hrFindSnap.data.data}} || [];\nconst arr = Array.isArray(raw) ? raw : [];\n\nif (arr.length === 0) {\n  return {\n    snapshotFound: 0,\n    snapshotId: \"\",\n    preSoLines: [],\n    hasSoLines: 0,\n  };\n}\n\n// If multiple Actives somehow exist, take the most recently created.\nconst snapshot = arr.length === 1 ? arr[0] : arr.slice().sort((a, b) => {\n  const at = new Date(a.create_time || 0).getTime();\n  const bt = new Date(b.create_time || 0).getTime();\n  return bt - at;\n})[0];\n\nconst parse = (raw, def) => {\n  if (raw === null || raw === undefined || raw === \"\") return def;\n  if (typeof raw === \"string\") {\n    try { return JSON.parse(raw); } catch (e) { return def; }\n  }\n  return raw;\n};\n\nconst preSoLines = parse(snapshot.pre_so_lines, []);\n\nreturn {\n  snapshotFound: 1,\n  snapshotId: snapshot.id,\n  preSoLines,\n  hasSoLines: preSoLines.length > 0 ? 1 : 0,\n};\n"
        },
        "response_json": [
          { "key": "hp1snfd01", "name": "snapshotFound", "title": "snapshotFound", "description": "", "bsonType": "int", "isExpand": false, "children": [] },
          { "key": "hp2snid02", "name": "snapshotId", "title": "snapshotId", "description": "", "bsonType": "string", "isExpand": false, "children": [] },
          { "key": "hp3psln03", "name": "preSoLines", "title": "preSoLines", "description": "", "bsonType": "array", "isExpand": false, "children": [] },
