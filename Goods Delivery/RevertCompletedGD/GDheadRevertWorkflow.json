        "script": {
          "type": "javascript",
          "code": "// Extract the scalars + tableData we need for SO restore + downstream inventory revert call.\nconst allData = {{workflowparams:allData}} || {};\n\nconst gdId = allData.id || \"\";\nconst gdNo = allData.delivery_no || allData.gd_no || \"\";\nconst gdStatus = allData.gd_status || \"\";\nconst plantId = allData.plant_id || \"\";\nconst organizationId = allData.organization_id || \"\";\nconst tableData = Array.isArray(allData.table_gd) ? allData.table_gd : [];\n\n// Extract SO line + SO header ids for current-state fetch (additive revert math).\nconst soLineItemIdsSet = new Set();\nconst soHeaderIdsSet = new Set();\nfor (const row of tableData) {\n  if (row.so_line_item_id) soLineItemIdsSet.add(row.so_line_item_id);\n  if (row.line_so_id) soHeaderIdsSet.add(row.line_so_id);\n}\nconst soLineItemIds = [...soLineItemIdsSet];\nconst soHeaderIds = [...soHeaderIdsSet];\n\n// Format current date as 'YYYY-MM-DD HH:mm:ss' for the doc_date param sent to ADD_INVENTORY_NEW.\nconst pad = (n) => (n < 10 ? \"0\" + n : \"\" + n);\nconst d = new Date();\nconst docDate = d.getFullYear() + \"-\" + pad(d.getMonth() + 1) + \"-\" + pad(d.getDate()) + \" \" + pad(d.getHours()) + \":\" + pad(d.getMinutes()) + \":\" + pad(d.getSeconds());\n\nreturn {\n  gdId,\n  gdNo,\n  gdStatus,\n  plantId,\n  organizationId,\n  tableData,\n  soLineItemIds,\n  soHeaderIds,\n  transactionType: \"GDL-R\",\n  docDate,\n  isCompleted: gdStatus === \"Completed\" ? 1 : 0,\n  hasSoLineItemIds: soLineItemIds.length > 0 ? 1 : 0,\n  hasSoHeaderIds: soHeaderIds.length > 0 ? 1 : 0,\n};\n"
        },
        "response_json": [
