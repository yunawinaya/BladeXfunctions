    {
      "id": "code_node_hrComputeSoUpdates",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Compute Additive SO Updates",
        "isValidator": true,
        "nodeName": "Compute Additive SO Updates",
        "name": "Compute Additive SO Updates",
        "script": {
          "type": "javascript",
          "code": "// Compute additive SO line + aggregated SO header updates for revert.\n// Math mirrors completion's inverse: delivered -= gdQty, planned += gdQty.\n// This preserves other GDs' contributions when multiple GDs target the same SO.\n\nconst tableData = {{node:code_node_hrExtract.data.tableData}} || [];\nconst curSoLinesRaw = {{node:search_node_hrCurSoLines.data.data}} || [];\nconst curSoHdrsRaw = {{node:search_node_hrCurSoHdr.data.data}} || [];\nconst curSoLines = Array.isArray(curSoLinesRaw) ? curSoLinesRaw : [curSoLinesRaw];\nconst curSoHdrs = Array.isArray(curSoHdrsRaw) ? curSoHdrsRaw : [curSoHdrsRaw];\n\nconst roundQty = (v) => {\n  if (v === null || v === undefined || v === \"\") return 0;\n  return Math.round(parseFloat(v) * 1000) / 1000;\n};\nconst formatNumber = (v) => {\n  if (v === null || v === undefined || v === \"\") return \"0.000\";\n  return parseFloat(v).toFixed(3);\n};\n\n// Aggregate this GD's gd_qty contribution per so_line_item_id (handles multiple\n// GD rows targeting the same SO line — rare but possible).\nconst gdQtyBySoLine = {};\nfor (const row of tableData) {\n  if (!row.so_line_item_id) continue;\n  const qty = parseFloat(row.gd_qty) || 0;\n  gdQtyBySoLine[row.so_line_item_id] = roundQty((gdQtyBySoLine[row.so_line_item_id] || 0) + qty);\n}\n\n// Build SO line updates (additive reverse of completion).\nconst soLineUpdates = [];\nconst newLineStateById = {}; // for header aggregation\nfor (const soLine of curSoLines) {\n  const lineId = soLine.id;\n  const gdQty = gdQtyBySoLine[lineId] || 0;\n  const curDelivered = parseFloat(soLine.delivered_qty) || 0;\n  const curPlanned = parseFloat(soLine.planned_qty) || 0;\n  const soQuantity = parseFloat(soLine.so_quantity) || 0;\n  const newDelivered = Math.max(0, roundQty(curDelivered - gdQty));\n  const newPlanned = roundQty(curPlanned + gdQty);\n  const newOutstanding = Math.max(0, roundQty(soQuantity - newDelivered));\n\n  // line_status recompute:\n  // - newDelivered >= soQuantity > 0 → \"Completed\" (other GDs still cover it)\n  // - newDelivered > 0 → \"Processing\" (partial)\n  // - newDelivered === 0 → empty (back to pre-delivery state)\n  let newLineStatus;\n  if (soQuantity > 0 && newDelivered >= soQuantity) {\n    newLineStatus = \"Completed\";\n  } else if (newDelivered > 0) {\n    newLineStatus = \"Processing\";\n  } else {\n    newLineStatus = \"\";\n  }\n\n  soLineUpdates.push({\n    id: lineId,\n    planned_qty: formatNumber(newPlanned),\n    delivered_qty: formatNumber(newDelivered),\n    outstanding_quantity: formatNumber(newOutstanding),\n    line_status: newLineStatus,\n  });\n  newLineStateById[lineId] = {\n    delivered_qty: newDelivered,\n    so_quantity: soQuantity,\n    line_status: newLineStatus,\n  };\n}\n\n// Build SO header aggregated updates. Mirror of completion's code_node_lwB2FVe0\n// (Completed branch): count fully/partially delivered across ALL table_so lines,\n// using newLineStateById for lines we just updated and existing values for others.\nconst soHeaderUpdates = [];\nfor (const soHdr of curSoHdrs) {\n  const tableSo = Array.isArray(soHdr.table_so) ? soHdr.table_so : [];\n  const totalItems = tableSo.length;\n  let partiallyDeliveredItems = 0;\n  let fullyDeliveredItems = 0;\n\n  for (const soItem of tableSo) {\n    const updated = newLineStateById[soItem.id];\n    const lineToCheck = updated || soItem;\n    const deliveredQty = parseFloat(lineToCheck.delivered_qty || 0);\n    const soQty = parseFloat(lineToCheck.so_quantity || 0);\n    const lineStatus = lineToCheck.line_status;\n\n    if (lineStatus === \"Completed\" || (deliveredQty >= soQty && soQty > 0)) {\n      partiallyDeliveredItems++;\n      fullyDeliveredItems++;\n    } else if (deliveredQty > 0) {\n      partiallyDeliveredItems++;\n    }\n  }\n\n  const allItemsComplete = fullyDeliveredItems === totalItems && totalItems > 0;\n  const anyItemProcessing = partiallyDeliveredItems > 0;\n\n  // Derive SO header status from new line state:\n  // - all delivered → so_status=\"Completed\", gd_status=\"Fully Delivered\"\n  // - any partial → so_status=\"Processing\", gd_status=\"Partially Delivered\"\n  // - none delivered → so_status=\"Issued\" (revert to pre-delivery), gd_status=\"Created\"\n  //   (any GD still tied to this SO leaves gd_status=\"Created\"; we don't know about\n  //   other Created/Completed GDs here, so default to \"Created\" — completion's\n  //   own Created-path also sets \"Created\" when prev was empty/Cancelled.)\n  let newSoStatus;\n  let newGdStatus;\n  if (allItemsComplete) {\n    newSoStatus = \"Completed\";\n    newGdStatus = \"Fully Delivered\";\n  } else if (anyItemProcessing) {\n    newSoStatus = \"Processing\";\n    newGdStatus = \"Partially Delivered\";\n  } else {\n    newSoStatus = \"Issued\";\n    newGdStatus = \"Created\";\n  }\n\n  soHeaderUpdates.push({\n    id: soHdr.id,\n    so_status: newSoStatus,\n    gd_status: newGdStatus,\n    partially_delivered: totalItems > 0 ? (partiallyDeliveredItems + \" / \" + totalItems) : \"0 / 0\",\n    fully_delivered: totalItems > 0 ? (fullyDeliveredItems + \" / \" + totalItems) : \"0 / 0\",\n  });\n}\n\nreturn {\n  soLineUpdates,\n  soHeaderUpdates,\n  hasSoLineUpdates: soLineUpdates.length > 0 ? 1 : 0,\n  hasSoHeaderUpdates: soHeaderUpdates.length > 0 ? 1 : 0,\n};\n"
        },
        "response_json": [
          { "key": "hcs1lupd01", "name": "soLineUpdates", "title": "soLineUpdates", "description": "", "bsonType": "array", "isExpand": false, "children": [] },
          { "key": "hcs2hupd02", "name": "soHeaderUpdates", "title": "soHeaderUpdates", "description": "", "bsonType": "array", "isExpand": false, "children": [] },
          { "key": "hcs3hsli03", "name": "hasSoLineUpdates", "title": "hasSoLineUpdates", "description": "", "bsonType": "int", "isExpand": false, "children": [] },
          { "key": "hcs4hshi04", "name": "hasSoHeaderUpdates", "title": "hasSoHeaderUpdates", "description": "", "bsonType": "int", "isExpand": false, "children": [] }
        ]
      },
      "blocks": []
