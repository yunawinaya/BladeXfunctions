          "type": "javascript",
          "code": "// Extract scalars and ID arrays from allData for downstream queries.\nconst allData = {{workflowparams:allData}} || {};\n\nconst gd_id = allData.id || \"\";\nconst gd_no = allData.delivery_no || allData.gd_no || \"\";\nconst organization_id = allData.organization_id || \"\";\nconst plant_id = allData.plant_id || \"\";\nconst completed_by = allData.update_user || allData.gd_created_by || \"\";\n// Format as 'YYYY-MM-DD HH:MM:SS' for MySQL datetime column. Returning a ms-epoch\n// integer here is unsafe: bsonType=decimal can be serialized in scientific notation\n// (e.g. 1.77976684661E+12) which MySQL rejects as a datetime value.\nconst pad = (n) => (n < 10 ? \"0\" + n : \"\" + n);\nconst _now = new Date();\nconst completed_at = _now.getFullYear() + \"-\" + pad(_now.getMonth() + 1) + \"-\" + pad(_now.getDate()) + \" \" + pad(_now.getHours()) + \":\" + pad(_now.getMinutes()) + \":\" + pad(_now.getSeconds());\n\nconst table_gd = Array.isArray(allData.table_gd) ? allData.table_gd : [];\n\nconst materialIdsSet = new Set();\nconst parentLineIdsSet = new Set();\nconst soHeaderIdsSet = new Set();\nconst pickingRecordIdsSet = new Set();\nconst ppHeaderIdsSet = new Set();\nconst ppPlanHeaderIdsSet = new Set();\nconst handlingUnitIdsSet = new Set();\n\nconst parseTempData = (raw) => {\n  if (!raw) return [];\n  if (typeof raw === \"string\") {\n    try { return JSON.parse(raw); } catch (e) { return []; }\n  }\n  return Array.isArray(raw) ? raw : [];\n};\n\nfor (const item of table_gd) {\n  if (item.material_id) materialIdsSet.add(item.material_id);\n  if (item.so_line_item_id) parentLineIdsSet.add(item.so_line_item_id);\n  if (item.line_so_id) soHeaderIdsSet.add(item.line_so_id);\n  if (item.line_to_id) ppHeaderIdsSet.add(item.line_to_id);\n  // PP Plan header id (line_pp_id) — for PP-restamp capture: PP-allocated\n  // on_reserved_gd records have target_gd_id set to this PP header id pre-completion.\n  // Completion restamps them to GD identity; revert restores from pp_restamp_map.\n  if (item.line_pp_id) ppPlanHeaderIdsSet.add(item.line_pp_id);\n\n  const tempData = parseTempData(item.temp_qty_data);\n  for (const t of tempData) {\n    if (t.picking_record_id) pickingRecordIdsSet.add(t.picking_record_id);\n    if (t.handling_unit_id) handlingUnitIdsSet.add(t.handling_unit_id);\n  }\n}\n\nconst materialIds = [...materialIdsSet];\nconst parentLineIds = [...parentLineIdsSet];\nconst soHeaderIds = [...soHeaderIdsSet];\nconst pickingRecordIds = [...pickingRecordIdsSet];\nconst ppHeaderIds = [...ppHeaderIdsSet];\nconst ppPlanHeaderIds = [...ppPlanHeaderIdsSet];\nconst handlingUnitIds = [...handlingUnitIdsSet];\n\n// Combined scope for the Allocated on_reserved_gd query.\n// Includes the GD id (for Edit-mode where records already target the GD,\n// or post-Save-Created for PP-linked GDs after restamping) AND PP header ids\n// (for Add-mode PP-linked GDs where PP records still target the PP at snapshot time).\nconst reservedGdScopeIds = gd_id\n  ? [gd_id, ...ppPlanHeaderIds]\n  : [...ppPlanHeaderIds];\n\nreturn {\n  gd_id,\n  gd_no,\n  organization_id,\n  plant_id,\n  completed_by,\n  completed_at,\n  materialIds,\n  parentLineIds,\n  soHeaderIds,\n  pickingRecordIds,\n  ppHeaderIds,\n  ppPlanHeaderIds,\n  reservedGdScopeIds,\n  handlingUnitIds,\n  hasMaterials: materialIds.length > 0 ? 1 : 0,\n  hasParentLines: parentLineIds.length > 0 ? 1 : 0,\n  hasSoHeaders: soHeaderIds.length > 0 ? 1 : 0,\n  hasPickingRecords: pickingRecordIds.length > 0 ? 1 : 0,\n  hasPPHeaders: ppHeaderIds.length > 0 ? 1 : 0,\n  hasPPPlanHeaders: ppPlanHeaderIds.length > 0 ? 1 : 0,\n  hasReservedGdScope: reservedGdScopeIds.length > 0 ? 1 : 0,\n  hasHandlingUnits: handlingUnitIds.length > 0 ? 1 : 0,\n};\n"
        },
