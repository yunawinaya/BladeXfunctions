    {
      "id": "code_node_PYFZeGpr",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Map Picking Data",
        "isValidator": true,
        "nodeName": "Map Picking Data",
        "name": "Map Picking Data",
        "script": {
          "type": "javascript",
          "code": "const mapLineItem = (gdData) => {\n  let tablePickingItems = [];\n  const pickingItemGroups = new Map();\n\n  for (const item of gdData.table_gd) {\n    if (item.temp_qty_data && item.material_id) {\n      const tempData = JSON.parse(item.temp_qty_data);\n      for (const tempItem of tempData) {\n        const materialId = String(tempItem.material_id) || String(item.material_id);\n        const groupKey = `${item.id}_${materialId}_${\n          tempItem.batch_id || \"no-batch\"\n        }_${tempItem.location_id}_${tempItem.handling_unit_id || \"no-hu\"}`;\n\n        if (!pickingItemGroups.has(groupKey)) {\n          pickingItemGroups.set(groupKey, {\n            item_code: String(materialId),\n            item_name: item.material_name,\n            item_desc: item.gd_material_desc || \"\",\n            batch_no: tempItem.batch_id ? String(tempItem.batch_id) : null,\n            qty_to_pick: 0,\n            item_uom: String(item.good_delivery_uom_id),\n            source_bin: String(tempItem.location_id),\n            pending_process_qty: 0,\n            line_status: \"Open\",\n            so_no: item.line_so_no,\n            gd_no: gdData.delivery_no,\n            so_id: String(item.line_so_id),\n            so_line_id: String(item.so_line_item_id),\n            gd_id: String(gdData.id),\n            gd_line_id: String(item.id),\n            serial_numbers: [],\n            is_serialized_item: 0,\n            handling_unit_id: tempItem.handling_unit_id ? String(tempItem.handling_unit_id) : null,\n          });\n\n        }\n\n        const group = pickingItemGroups.get(groupKey);\n        group.qty_to_pick += parseFloat(tempItem.gd_quantity);\n        group.pending_process_qty += parseFloat(tempItem.gd_quantity);\n\n        if (tempItem.serial_number) {\n          group.serial_numbers.push(String(tempItem.serial_number));\n          group.is_serialized_item = 1;\n        }\n      }\n    }\n  }\n  \n  for (const group of pickingItemGroups.values()) {\n    if (group.serial_numbers.length > 0) {\n      group.serial_numbers = group.serial_numbers.join(\", \");\n    } else {\n      delete group.serial_numbers;\n    }\n\n    tablePickingItems.push({ ...group });\n  }\n\n  tablePickingItems.sort((a, b) => {\n    if (a.gd_line_id !== b.gd_line_id) return 0;\n    const aHU = a.handling_unit_id || \"\";\n    const bHU = b.handling_unit_id || \"\";\n    if (aHU === bHU) return 0;\n    return aHU < bHU ? -1 : 1;\n  });\n\n  const withHeaders = [];\n  let lastHuId = null;\n  for (const row of tablePickingItems) {\n    const huId = row.handling_unit_id;\n    if (huId && huId !== lastHuId) {\n      withHeaders.push({\n        row_type: \"header\",\n        handling_unit_id: huId,\n        hu_select: 0,\n      });\n      lastHuId = huId;\n    } else if (!huId) {\n      lastHuId = null;\n    }\n    withHeaders.push({ ...row, row_type: \"item\" });\n  }\n  tablePickingItems = withHeaders;\n\n  return tablePickingItems;\n};\n\nconst mapToPickingData = (\n  pickingLineItemPromises,\n  gdIDs,\n  gdNos,\n  soNos,\n  gdCustomers,\n  plantID\n) => {\n  return {\n    so_no: soNos,\n    delivery_no: gdNos,\n    gd_no: gdIDs,\n    ref_doc_type: \"Goods Delivery\",\n    table_picking_items: pickingLineItemPromises,\n    customer_id: gdCustomers,\n    plant_id: plantID,\n  };\n};\n\nlet gdData = {{node:search_node_IUyBiDce.data.data}};\ngdData = gdData.map((item) => ({\n  ...item,\n  table_gd: item.table_gd.filter((gdItem) => gdItem.picking_status === 'Not Created')\n}));\n\nconst gdIDs = gdData.map((gd) => String(gd.id));\nconst gdNos = gdData.map((gd) => gd.delivery_no).join(', ');\nconst soNos = [\n  ...new Set(gdData.flatMap((gd) => gd.so_no.split(', ')))\n].join(', ');\nconst gdCustomers = [ ...new Set(gdData.map((gd) => String(gd.customer_name)))];\nconst plantID = {{workflowparams:plant_id}};\nlet pickingLineItemPromises = [];\n\nfor(const gd of gdData) {\n  const lineItemPromise = mapLineItem(gd);\n  pickingLineItemPromises.push(...lineItemPromise);\n}\n\nconst pickingData = mapToPickingData(pickingLineItemPromises, gdIDs, gdNos, soNos, gdCustomers, plantID);\n\nreturn pickingData;"
        },
