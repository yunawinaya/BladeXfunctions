                  "code": "const grList = {{node:search_node_bOF3TVA2.data.data}}\nconst isMultiple = {{workflowparams:is_multiple}}\nlet suppliers = new Set(grList.map((gr) => gr.supplier_name));\nlet plants = new Set(grList.map((gr) => gr.plant_id));\nif (suppliers.size > 1 && isMultiple === \"single\") {\n  return {\n    status: \"Failed\",\n    code: 403,\n    message:\n      \"All selected Goods Receiving(s) must be from the same supplier to create a single Purchase Invoice.\",\n  };\n} else if (plants.size > 1 && isMultiple === \"single\") {\n  return {\n    status: \"Failed\",\n    code: 403,\n    message:\n      \"All selected Goods Receiving(s) must be from the same plant to create a single Purchase Invoice.\",\n  };\n} else {\n  return {\n    status: \"Success\",\n    code: 200,\n    message: \"\",\n  };\n}\n"
