                    {
                      "id": "code_node_sQX9tldw",
                      "type": "code-node",
                      "data": {
                        "language": "javascript",
                        "code": "",
                        "timeout": 30000,
                        "title": "5. Map PI Data",
                        "isValidator": true,
                        "nodeName": "5. Map PI Data",
                        "name": "5. Map PI Data",
                        "script": {
                          "type": "javascript",
                          "code": "const grList = {{node:search_node_bOF3TVA2.data.data}};\nconst isMultiple = {{workflowparams:is_multiple}};\nconst convertTo = {{workflowparams:convert_to}};\nconst docFormat = {{node:get_node_yDMG0Sab.data.data}};\nconst poLineItemList = {{node:search_node_r3bnMaWy.data.data}};\nconst poList = {{node:search_node_Ivek0yYx.data.data}};\nlet piList = [];\n\nconst mapLineItem = (grItem, poLineItem, record, index, poData, plantID) => {\n  // Calculate based on GR quantity\n  const grQuantity = parseFloat(grItem.received_qty) || 0;\n  const poQuantity = parseFloat(poLineItem.quantity) || 1;\n  const unitPrice = parseFloat(poLineItem.unit_price) || 0;\n  let discount = parseFloat(poLineItem.discount) || 0;\n  const discountAmount = parseFloat(poLineItem.discount_amount) || 0;\n  const taxAmount = parseFloat(poLineItem.tax_amount) || 0;\n  const totalAmount = parseFloat(poLineItem.po_amount) || 0;\n\n  // Recalculate amounts based on GR quantity\n  const ratio = poQuantity > 0 ? grQuantity / poQuantity : 0;\n  const recalculatedGross = unitPrice * grQuantity;\n  const recalculatedDiscountAmount = discountAmount * ratio;\n  const recalculatedTaxAmount = taxAmount * ratio;\n  const recalculatedAmount = totalAmount * ratio;\n\n  if (poLineItem.discount_uom && poLineItem.discount_uom === \"Amount\") {\n    discount = discount * ratio;\n  }\n\n  const lineItemPromise = {\n    material_id: grItem.item_id,\n    material_name: grItem.item_name,\n    item_desc: grItem.item_desc,\n    more_desc: grItem.more_desc,\n    purchase_order_no: grItem.line_po_no,\n    order_qty: poQuantity,\n    received_qty: grQuantity,\n    invoice_qty: grQuantity,\n    quantity_uom: grItem.item_uom,\n    order_unit_price: unitPrice,\n    order_gross: recalculatedGross.toFixed(4),\n    order_discount: discount.toFixed(4),\n    discount_uom: poLineItem.discount_uom,\n    discount_amount: recalculatedDiscountAmount.toFixed(4),\n    tax_preference: poLineItem.tax_preference,\n    tax_percent: poLineItem.tax_percent,\n    tax_amount: recalculatedTaxAmount.toFixed(4),\n    tax_inclusive: poLineItem.tax_inclusive,\n    invoice_amount: recalculatedAmount.toFixed(4),\n    line_remark_1: grItem.line_remark_1,\n    line_remark_2: grItem.line_remark_2,\n    available_inv_qty:\n      parseFloat(poLineItem.quantity || 0) -\n      parseFloat(poLineItem.invoice_qty || 0),\n    goods_receiving_no: record.gr_no,\n    gr_line_id: grItem.id,\n    line_po_id: grItem.line_po_id,\n    line_gr_id: record.id,\n    po_line_id: grItem.po_line_item_id,\n    item_category_id: grItem.item_category_id,\n    line_index: index + 1,\n    billing_country_id: grItem.billing_country_id,\n    agent_id: null,\n    shipping_country_id: grItem.shipping_country_id,\n    billing_state_id: grItem.billing_state_id,\n    supplier_id: grItem.supplier_id,\n    shipping_state_id: null,\n    plant_id: plantID,\n    tariff_id: grItem.tariff_id,\n    payment_term_id: poLineItem.payment_term_id,\n\n    exchange_rate:\n      parseFloat(poData.exchange_rate) === 0\n        ? 1\n        : parseFloat(poData.exchange_rate),\n    exchange_rate_currency: poData.exchange_rate_currency,\n  };\n\n  return lineItemPromise;\n};\n\nconst mapHeaderData = (\n  record,\n  lineItemPromise,\n  poNoDisplay,\n  poID,\n  grNoDisplay,\n  grID,\n  totals,\n) => {\n  const data = {\n    page_status: \"Add\",\n    purchase_invoice_no: convertTo === \"draft\" ? \"draft\" : \"issued\",\n    invoice_date: new Date().toISOString().split(\"T\")[0],\n    exchange_rate: lineItemPromise[0].exchange_rate,\n    invoice_payment_term_id: lineItemPromise[0].payment_term_id,\n    pi_description: \"Purchase\",\n    table_pi: lineItemPromise,\n    invoice_subtotal: totals.invoice_subtotal,\n    invoice_total_discount: totals.invoice_total_discount,\n    invoice_taxes_amount: totals.invoice_taxes_amount,\n    invoice_total: totals.invoice_total,\n    remarks: record.gr_remark1,\n    currency_code: record.currency_code,\n    billing_address_name: record.billing_address_name,\n    billing_address_phone: record.billing_address_phone,\n    billing_address_line_1: record.billing_address_line_1,\n    billing_address_line_2: record.billing_address_line_2,\n    billing_address_line_3: record.billing_address_line_3,\n    billing_address_line_4: record.billing_address_line_4,\n    billing_address_city: record.billing_address_city,\n    billing_postal_code: record.billing_postal_code,\n    billing_address_state: record.billing_address_state,\n    billing_address_country: record.billing_address_country,\n    billing_attention: record.billing_attention,\n    billing_address_fax: record.billing_address_fax,\n    shipping_address_name: record.shipping_address_name,\n    shipping_address_phone: record.shipping_address_phone,\n    shipping_address_line_1: record.shipping_address_line_1,\n    shipping_address_line_2: record.shipping_address_line_2,\n    shipping_address_line_3: record.shipping_address_line_3,\n    shipping_address_line_4: record.shipping_address_line_4,\n    shipping_address_city: record.shipping_address_city,\n    shipping_postal_code: record.shipping_postal_code,\n    shipping_address_state: record.shipping_address_state,\n    shipping_address_country: record.shipping_address_country,\n    shipping_attention: record.shipping_attention,\n    shipping_address_fax: record.shipping_address_fax,\n    pi_billing_address: record.gr_billing_address,\n    pi_shipping_address: record.gr_shipping_address,\n    supplier_name: record.supplier_name,\n    pi_status: convertTo === \"draft\" ? \"Draft\" : \"Completed\",\n    posted_status: convertTo === \"draft\" ? \"\" : \"Unposted\",\n    plant_id: record.plant_id,\n    organization_id: record.organization_id,\n    gr_no_display: grNoDisplay,\n    myr_total_amount: totals.myr_total_amount,\n    po_no_display: poNoDisplay,\n    total_amount_currency: record.currency_code,\n    exchange_rate_currency: record.currency_code,\n    total_discount_currency: record.currency_code,\n    total_tax_currency: record.currency_code,\n    total_gross_currency: record.currency_code,\n    po_id: poID,\n    gr_id: grID,\n    remarks2: record.gr_remark2,\n    remarks3: record.gr_remark3,\n    purchase_invoice_no_type: docFormat.id,\n    remarks4: record.gr_remark4,\n    remarks5: record.gr_remark5,\n  };\n\n  return data;\n};\n\n// Helper function to calculate totals from GR lines\nconst calculateTotalsFromGrLines = (grLines) => {\n  let totals = {\n    invoice_subtotal: 0,\n    invoice_total_discount: 0,\n    invoice_taxes_amount: 0,\n    invoice_total: 0,\n    myr_total_amount: 0,\n  };\n\n  for (const grLine of grLines) {\n    totals.invoice_subtotal += parseFloat(grLine.recalculated_gross) || 0;\n    totals.invoice_total_discount +=\n      parseFloat(grLine.recalculated_discount_amount) || 0;\n    totals.invoice_taxes_amount +=\n      parseFloat(grLine.recalculated_tax_amount) || 0;\n    totals.invoice_total += parseFloat(grLine.recalculated_amount) || 0;\n    totals.myr_total_amount += parseFloat(grLine.myr_amount) || 0;\n  }\n\n  totals.invoice_subtotal = totals.invoice_subtotal.toFixed(4);\n  totals.invoice_total_discount = totals.invoice_total_discount.toFixed(4);\n  totals.invoice_taxes_amount = totals.invoice_taxes_amount.toFixed(4);\n  totals.invoice_total = totals.invoice_total.toFixed(4);\n  totals.myr_total_amount = totals.myr_total_amount.toFixed(4);\n\n  return totals;\n};\n\n// Helper function to find matching PO line item\nconst findPoLineItem = (grItem, poLineItemList) => {\n  return poLineItemList.find((item) => item.id === grItem.po_line_item_id);\n};\n\nconst findPOData = (grItem, poList) => {\n  return poList.find((item) => item.id === grItem.line_po_id);\n};\n\n// Process GR list and create PI\nconst processGrList = (grListData) => {\n  const piLineItems = [];\n  let lineCounter = 0;\n  let allGrLines = [];\n  const plantID = grListData[0].plant_id;\n\n  for (const gr of grListData) {\n    // Get GR lines\n    const grLines = gr.table_gr || [];\n\n    for (const grItem of grLines) {\n      // Find matching PO line item\n      const poLineItem = findPoLineItem(grItem, poLineItemList);\n      const poData = findPOData(grItem, poList);\n\n      if (poLineItem) {\n        // Calculate amounts based on GR quantity\n        const grQuantity = parseFloat(grItem.received_qty) || 0;\n        const poQuantity = parseFloat(poLineItem.quantity);\n        const unitPrice = parseFloat(poLineItem.unit_price) || 0;\n        const discountAmount = parseFloat(poLineItem.discount_amount) || 0;\n        const taxAmount = parseFloat(poLineItem.tax_amount) || 0;\n        const totalAmount = parseFloat(poLineItem.po_amount) || 0;\n\n        const ratio = poQuantity > 0 ? grQuantity / poQuantity : 0;\n        const recalculatedGross = unitPrice * grQuantity;\n        const recalculatedDiscountAmount = discountAmount * ratio;\n        const recalculatedTaxAmount = taxAmount * ratio;\n        const recalculatedAmount = totalAmount * ratio;\n\n        const lineItem = mapLineItem(\n          grItem,\n          poLineItem,\n          gr,\n          lineCounter,\n          poData,\n          plantID,\n        );\n\n        // Store recalculated values for totals calculation\n        grItem.recalculated_gross = recalculatedGross;\n        grItem.recalculated_discount_amount = recalculatedDiscountAmount;\n        grItem.recalculated_tax_amount = recalculatedTaxAmount;\n        grItem.recalculated_amount = recalculatedAmount;\n        grItem.myr_amount =\n          recalculatedAmount * (parseFloat(poData.exchange_rate) || 1);\n\n        allGrLines.push(grItem);\n        piLineItems.push(lineItem);\n        lineCounter++;\n      }\n    }\n  }\n\n  return { piLineItems, allGrLines };\n};\n\nif (isMultiple === \"multiple\") {\n  for (const grData of grList) {\n    const { piLineItems, allGrLines } = processGrList([grData]);\n    const totals = calculateTotalsFromGrLines(allGrLines);\n    const poNoDisplay = grData.purchase_order_number;\n    const poID = grData.po_id;\n    const grNoDisplay = grData.gr_no;\n    const grID = [grData.id];\n    const mappedData = mapHeaderData(\n      grData,\n      piLineItems,\n      poNoDisplay,\n      poID,\n      grNoDisplay,\n      grID,\n      totals,\n    );\n    piList.push(mappedData);\n  }\n} else if (isMultiple === \"single\") {\n  const grData = grList[0];\n  const { piLineItems, allGrLines } = processGrList(grList);\n  const totals = calculateTotalsFromGrLines(allGrLines);\n  const poNoDisplay = grList\n    .map((item) => item.purchase_order_number)\n    .join(\", \");\n  const poID = grList.flatMap((gr) => gr.po_id || []);\n  const grNoDisplay = grList.map((item) => item.gr_no).join(\", \");\n  const grID = grList.map((item) => item.id);\n  const mappedData = mapHeaderData(\n    grData,\n    piLineItems,\n    poNoDisplay,\n    poID,\n    grNoDisplay,\n    grID,\n    totals,\n  );\n  piList.push(mappedData);\n}\n\nreturn { piList };\n"
