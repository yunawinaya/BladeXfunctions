    {
      "id": "code_map_po",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Map Updated PO",
        "isValidator": true,
        "nodeName": "Map Updated PO",
        "name": "Map Updated PO",
        "script": {
          "type": "javascript",
          "code": "const poList = {{node:search_po_data.data.data}} || [];\nconst piList = {{node:search_success_pi.data.data}} || [];\n\nconst roundTo3 = (v) => Math.round((parseFloat(v) || 0) * 1000) / 1000;\n\nlet allPiLines = [];\nfor (const pi of piList) {\n  allPiLines = allPiLines.concat(pi.table_pi || []);\n}\n\nconst processItems = (items, tablePi, docId, docIdKey, piLineIdKey, qtyKey) => {\n  const filteredPI = tablePi.filter((item) => item[docIdKey] === docId);\n\n  const countableItems = items.filter((item) => item.parent_or_child !== \"Child\");\n  let totalItems = countableItems.length;\n  let partiallyPostedItems = 0;\n  let fullyPostedItems = 0;\n\n  const updatedItems = items.map((item) => {\n    const matchedPI = filteredPI.find((pi) => pi[piLineIdKey] === item.id);\n    if (matchedPI) {\n      const piQty = roundTo3(matchedPI.invoice_qty);\n      const currentPosted = roundTo3(item.posted_qty);\n      return { ...item, posted_qty: roundTo3(currentPosted + piQty) };\n    }\n    return { ...item };\n  });\n\n  for (const item of updatedItems) {\n    if (item.parent_or_child === \"Child\") continue;\n    if (roundTo3(item.posted_qty) > 0) {\n      partiallyPostedItems++;\n      if (roundTo3(item.posted_qty) >= roundTo3(item[qtyKey] || 0)) {\n        fullyPostedItems++;\n      }\n    }\n  }\n\n  const allComplete = fullyPostedItems === totalItems;\n  const anyProcessing = partiallyPostedItems > 0;\n  const newStatus = anyProcessing ? (allComplete ? \"Fully Posted\" : \"Partially Posted\") : \"\";\n\n  return { updatedItems, newStatus };\n};\n\nlet updatedPO = [];\nfor (const po of poList) {\n  const poItems = po.table_po || [];\n  const { updatedItems, newStatus } = processItems(poItems, allPiLines, po.id, \"line_po_id\", \"po_line_id\", \"quantity\");\n  updatedPO.push({ po_id: po.id, pi_posted_status: newStatus, table_po: updatedItems });\n}\n\nreturn { updatedPO };"
        },
