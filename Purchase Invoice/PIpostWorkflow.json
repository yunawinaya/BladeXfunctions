      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Collect PO IDs",
        "isValidator": true,
        "nodeName": "Collect PO IDs",
        "name": "Collect PO IDs",
        "script": {
          "type": "javascript",
          "code": "const piList = {{node:search_success_pi.data.data}} || [];\n\nlet poIDs = [];\nfor (const pi of piList) {\n  const ids = Array.isArray(pi.po_id) ? pi.po_id : [pi.po_id];\n  poIDs.push(...ids);\n}\n\npoIDs = [...new Set(poIDs.filter(Boolean))];\n\nreturn { poIDs };"
