          "code": "const workflowResponse = {{workflowparams:acc_integration_type}} === 'SQL Accounting' ? {{node:workflow_sql_post.data}} : {{node:workflow_auto_post.data}};\n\nconst workflowResult = (workflowResponse && workflowResponse.results) || [];\nconst successResult = workflowResult.filter((item) => item.status === 'SUCCESS');\n\nconst piIDs = successResult.map((item) => item.id);\n\nreturn { piIDs };"
