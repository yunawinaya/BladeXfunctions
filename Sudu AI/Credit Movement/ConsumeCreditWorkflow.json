      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Compute Consumption",
        "isValidator": true,
        "nodeName": "Compute Consumption",
        "name": "Compute Consumption",
        "script": {
          "type": "javascript",
          "code": "const customer = {{node:get_node_cc_customer.data.data}} || {};\nconst amount = parseFloat({{workflowparams:credit_consume}}) || 0;\n\nconst subBefore = parseFloat(customer.monthly_remain_credit) || 0;\nconst reloadBefore = parseFloat(customer.flex_remain_credit) || 0;\n\n// Bucket rule preserved exactly from the original workflow: the reload bucket is\n// used only once the subscription bucket is exhausted AND reload has something.\n// Balances are allowed to go negative - there is deliberately no sufficiency check.\nconst source = (subBefore <= 0 && reloadBefore > 0) ? 'Flex' : 'Month';\n\nconst subAfter = source === 'Month' ? subBefore - amount : subBefore;\nconst reloadAfter = source === 'Flex' ? reloadBefore - amount : reloadBefore;\n\nconst movement = {\n  customer_id: customer.id,\n  transaction_type: 'AI Usage',\n  ai_credit_source: source,\n  ai_credit_amount: Math.round(amount),\n  monthly_previous_balance: Math.round(subBefore),\n  monthly_balance_after: Math.round(subAfter),\n  flex_previous_balance: Math.round(reloadBefore),\n  flex_balance_after: Math.round(reloadAfter),\n  dealer_id: '',\n  agent_id: '',\n};\n\nreturn {\n  customerId: customer.id,\n  source,\n  amount: Math.round(amount),\n  subBefore: Math.round(subBefore),\n  subAfter: Math.round(subAfter),\n  reloadBefore: Math.round(reloadBefore),\n  reloadAfter: Math.round(reloadAfter),\n  movement,\n};"
        },
