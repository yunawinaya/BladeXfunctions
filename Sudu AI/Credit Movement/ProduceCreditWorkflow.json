    {
      "id": "code_pc_compute",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Compute Grant",
        "isValidator": true,
        "nodeName": "Compute Grant",
        "name": "Compute Grant",
        "script": {
          "type": "javascript",
          "code": "const customer = {{node:get_node_pc_customer.data.data}} || {};\nconst credits = parseFloat({{workflowparams:credit_produce}}) || 0;\nconst reloadType = '{{workflowparams:reload_type}}';\n\nconst subBefore = parseFloat(customer.sub_remain_credit) || 0;\nconst reloadBefore = parseFloat(customer.reload_remain_credit) || 0;\n\n// Monthly Subscription RESETS the subscription bucket - leftover credit does not\n// carry over. Add On accumulates onto the reload bucket.\nlet source = '';\nlet transactionType = '';\nlet subAfter = subBefore;\nlet reloadAfter = reloadBefore;\n\nif (reloadType === 'Monthly Subscription') {\n  source = 'Subscription';\n  transactionType = 'Monthly Grant';\n  subAfter = credits;\n} else if (reloadType === 'Add On') {\n  source = 'Reload';\n  transactionType = 'Paid Reload';\n  reloadAfter = reloadBefore + credits;\n}\n\nconst movement = {\n  customer_id: customer.id,\n  transaction_type: transactionType,\n  ai_credit_source: source,\n  ai_credit_amount: Math.round(credits),\n  sub_previous_balance: Math.round(subBefore),\n  sub_balance_after: Math.round(subAfter),\n  reload_previous_balance: Math.round(reloadBefore),\n  reload_balance_after: Math.round(reloadAfter),\n  dealer_id: '',\n  agent_id: '',\n};\n\nreturn {\n  customerId: customer.id,\n  source,\n  transactionType,\n  credits: Math.round(credits),\n  subBefore: Math.round(subBefore),\n  subAfter: Math.round(subAfter),\n  reloadBefore: Math.round(reloadBefore),\n  reloadAfter: Math.round(reloadAfter),\n  movement,\n};"
        },
