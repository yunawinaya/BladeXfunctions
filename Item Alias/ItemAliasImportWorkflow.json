    {
      "id": "code_resolve",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Resolve & Validate",
        "isValidator": true,
        "nodeName": "Resolve & Validate",
        "name": "Resolve & Validate",
        "script": {
          "type": "javascript",
          "code": "// Resolve org names -> ids and item codes -> ids (scoped to the resolved org),\n// derive/validate buyer & seller UOM, and validate every row. Any hard problem\n// accumulates into `errors` (-> code 400, nothing written). On success, de-duplicate\n// rows WITHIN the file and hand the unique candidates on.\nconst excelData = JSON.parse({{workflowparams:import_data}});\nconst orgList = {{node:search_org.data.data}} || [];\nconst itemList = {{node:search_item.data.data}} || [];\nconst uomList = {{node:search_uom.data.data}} || [];\n\nconst str = (v) => (v === undefined || v === null ? \"\" : String(v).trim());\n// The platform's equalAny search is case-INSENSITIVE, so match names/codes the same\n// way here (lowercased keys) -> a file \"Item-A\" still resolves a stored \"ITEM-A\".\nconst lc = (v) => str(v).toLowerCase();\n\n// org name -> [ids]  (detect not-found / ambiguous)\nconst orgByName = {};\norgList.forEach((o) => {\n  const name = lc(o.dept_name);\n  if (!name) return;\n  if (!orgByName[name]) orgByName[name] = [];\n  if (orgByName[name].indexOf(String(o.id)) === -1) orgByName[name].push(String(o.id));\n});\n\n// (material_code|organization_id) -> [{id, item}]  (detect ambiguous item within an org)\nconst itemByCodeOrg = {};\nitemList.forEach((it) => {\n  const code = lc(it.material_code);\n  const org = String(it.organization_id);\n  if (!code || !org) return;\n  const key = code + \"|\" + org;\n  if (!itemByCodeOrg[key]) itemByCodeOrg[key] = [];\n  itemByCodeOrg[key].push({ id: String(it.id), item: it });\n});\n\nconst resolveOrg = (name, errors, label, role) => {\n  if (!name) { errors.push(label + \": \" + role + \" Organization is required.\"); return \"\"; }\n  const ids = orgByName[lc(name)];\n  if (!ids || ids.length === 0) { errors.push(label + ': ' + role + ' Organization \"' + name + '\" not found.'); return \"\"; }\n  if (ids.length > 1) { errors.push(label + ': ' + role + ' Organization \"' + name + '\" is ambiguous.'); return \"\"; }\n  return ids[0];\n};\n\nconst resolveItem = (code, orgId, errors, label, role) => {\n  if (!orgId) return { id: \"\", item: null }; // org already errored; skip a second complaint\n  if (!code) { errors.push(label + \": \" + role + \" Item Code is required.\"); return { id: \"\", item: null }; }\n  const matches = itemByCodeOrg[lc(code) + \"|\" + orgId];\n  if (!matches || matches.length === 0) { errors.push(label + ': ' + role + ' Item Code \"' + code + '\" not found in the ' + role + ' Organization.'); return { id: \"\", item: null }; }\n  if (matches.length > 1) { errors.push(label + ': ' + role + ' Item Code \"' + code + '\" is ambiguous in the ' + role + ' Organization.'); return { id: \"\", item: null }; }\n  return { id: matches[0].id, item: matches[0].item };\n};\n\n// Resolve the buyer/seller UOM. Blank column -> the item's base UOM. When a UOM name\n// IS supplied we still validate it: the name must resolve to a UOM id valid for THIS\n// item (its based_uom or one of its table_uom_conversion rows). UOM names are not\n// globally unique, so match by name AND require a valid-for-item id.\nconst resolveUom = (match, uomNameRaw, errors, label, role) => {\n  if (!match || !match.id) return \"\"; // item already errored\n  const item = match.item || {};\n  const based = str(item.based_uom);\n  const conv = Array.isArray(item.table_uom_conversion) ? item.table_uom_conversion : [];\n  const validIds = {};\n  conv.forEach((c) => { const a = str(c.alt_uom_id); if (a) validIds[a] = true; });\n  if (based) validIds[based] = true;\n\n  const name = str(uomNameRaw);\n  if (!name) {\n    if (!based) { errors.push(label + \": \" + role + \" Item has no base UOM; please provide a \" + role + \" Item UOM.\"); return \"\"; }\n    return based;\n  }\n  const named = uomList.filter((u) => lc(u.uom_name) === lc(name));\n  if (named.length === 0) { errors.push(label + ': ' + role + ' Item UOM \"' + name + '\" not found.'); return \"\"; }\n  let matched = \"\";\n  for (let n = 0; n < named.length; n++) {\n    const id = String(named[n].id);\n    if (validIds[id]) { matched = id; break; }\n  }\n  if (!matched) { errors.push(label + ': ' + role + ' Item UOM \"' + name + '\" is not a valid UOM for this item.'); return \"\"; }\n  return matched;\n};\n\nconst rows = [];\nObject.keys(excelData).forEach((k) => {\n  if (/^\\d+$/.test(k)) rows.push({ idx: parseInt(k, 10), data: excelData[k] || {} });\n});\nrows.sort((a, b) => a.idx - b.idx);\n\nconst errors = [];\nconst candidates = [];\n\nrows.forEach((r, i) => {\n  const row = r.data;\n  const label = \"Row \" + (i + 1);\n  const buyerOrgName = str(row[\"Buyer Organization\"]);\n  const sellerOrgName = str(row[\"Seller Organization\"]);\n  const buyerCode = str(row[\"Buyer Item Code\"]);\n  const sellerCode = str(row[\"Seller Item Code\"]);\n\n  const buyerOrgId = resolveOrg(buyerOrgName, errors, label, \"Buyer\");\n  const sellerOrgId = resolveOrg(sellerOrgName, errors, label, \"Seller\");\n\n  if (buyerOrgId && sellerOrgId && buyerOrgId === sellerOrgId) {\n    errors.push(label + \": Buyer Organization and Seller Organization cannot be the same.\");\n  }\n\n  const buyer = resolveItem(buyerCode, buyerOrgId, errors, label, \"Buyer\");\n  const seller = resolveItem(sellerCode, sellerOrgId, errors, label, \"Seller\");\n  const buyerUom = resolveUom(buyer, row[\"Buyer Item UOM\"], errors, label, \"Buyer\");\n  const sellerUom = resolveUom(seller, row[\"Seller Item UOM\"], errors, label, \"Seller\");\n\n  const rate = parseFloat(row[\"Conversion Rate\"]);\n  if (isNaN(rate) || rate <= 0) {\n    errors.push(label + \": Conversion Rate must be a number greater than 0.\");\n  }\n\n  if (buyerOrgId && sellerOrgId && buyerOrgId !== sellerOrgId &&\n      buyer.id && buyerUom && seller.id && sellerUom &&\n      !isNaN(rate) && rate > 0) {\n    candidates.push({\n      buyer_org_id: buyerOrgId,\n      buyer_item_id: buyer.id,\n      buyer_uom_id: buyerUom,\n      seller_org_id: sellerOrgId,\n      seller_item_id: seller.id,\n      seller_uom_id: sellerUom,\n      // precision-3 decimal column validates multipleOf 0.001; a raw float (0.1 =\n      // 0.10000000000000000555...) fails BigDecimal, so write a fixed-precision STRING.\n      conversion_rate: rate.toFixed(3),\n      is_active: 1,\n      _label: 'Buyer \"' + buyerCode + '\" → Seller \"' + sellerCode + '\"',\n    });\n  }\n});\n\nif (errors.length > 0) {\n  return { code: \"400\", message: errors.join(\"\\n\"), entries: \"[]\", buyerItemIds: [\"0\"], dupInFile: \"[]\" };\n}\n\n// de-duplicate WITHIN the file on the per-seller uniqueness key; keep the first.\nconst seen = {};\nconst unique = [];\nconst dupInFile = [];\ncandidates.forEach((c) => {\n  const key = c.buyer_org_id + \"|\" + c.seller_org_id + \"|\" + c.buyer_item_id + \"|\" + c.buyer_uom_id;\n  if (seen[key]) { dupInFile.push(c._label); return; }\n  seen[key] = true;\n  unique.push(c);\n});\n\nconst buyerItemIds = [];\nunique.forEach((c) => { if (buyerItemIds.indexOf(c.buyer_item_id) === -1) buyerItemIds.push(c.buyer_item_id); });\nif (buyerItemIds.length === 0) buyerItemIds.push(\"0\");\n\nreturn {\n  code: \"200\",\n  message: \"\",\n  entries: JSON.stringify(unique),\n  buyerItemIds: buyerItemIds,\n  dupInFile: JSON.stringify(dupInFile),\n};\n"
        },
