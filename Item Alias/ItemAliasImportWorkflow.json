    {
      "id": "code_filter",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Filter Duplicates & Finalize",
        "isValidator": true,
        "nodeName": "Filter Duplicates & Finalize",
        "name": "Filter Duplicates & Finalize",
        "script": {
          "type": "javascript",
          "code": "// Split the unique candidates into rows to INSERT (no existing alias) and rows to\n// UPDATE (an active alias already exists for the same buyer-org/seller-org/buyer-item/\n// buyer-UOM key). On the first pass, if any already exist we return 409 so the client\n// can ask ONCE whether to update them; on confirm (updateExisting=\"true\") the existing\n// rows are updated and the new ones inserted. A 400 from resolve passes straight through.\nconst codeIn = {{node:code_resolve.data.code}};\nconst message = {{node:code_resolve.data.message}};\nconst entriesStr = {{node:code_resolve.data.entries}};\nconst dupInFileStr = {{node:code_resolve.data.dupInFile}};\nconst existing = {{node:search_existing.data.data}} || [];\nconst updateExisting = String({{workflowparams:updateExisting}} || \"\");\n\nif (String(codeIn) === \"400\") {\n  return { code: \"400\", message: message, toInsert: [], toUpdate: [], inserted: \"0\", updated: \"0\", warning: \"\", duplicates: \"\", hasInserts: false, hasUpdates: false };\n}\n\nlet candidates = [];\ntry { candidates = JSON.parse(entriesStr || \"[]\"); } catch (e) { candidates = []; }\nlet dupInFile = [];\ntry { dupInFile = JSON.parse(dupInFileStr || \"[]\"); } catch (e) { dupInFile = []; }\n\n// existing active aliases keyed by the uniqueness key -> the row (need its id to update)\nconst existingByKey = {};\nexisting.forEach((r) => {\n  const key = String(r.buyer_org_id) + \"|\" + String(r.seller_org_id) + \"|\" + String(r.buyer_item_id) + \"|\" + String(r.buyer_uom_id);\n  if (!existingByKey[key]) existingByKey[key] = r;\n});\n\nconst toInsert = [];\nconst toUpdate = [];\nconst dbDup = [];\ncandidates.forEach((c) => {\n  const key = c.buyer_org_id + \"|\" + c.seller_org_id + \"|\" + c.buyer_item_id + \"|\" + c.buyer_uom_id;\n  const ex = existingByKey[key];\n  if (ex) {\n    dbDup.push(c._label || key);\n    toUpdate.push({\n      id: String(ex.id),\n      seller_item_id: c.seller_item_id,\n      seller_uom_id: c.seller_uom_id,\n      conversion_rate: c.conversion_rate,\n      is_active: 1,\n      _label: c._label,\n    });\n  } else {\n    toInsert.push(c);\n  }\n});\n\n// First pass: some aliases already exist -> ask the user once (bulk) whether to update.\nif (dbDup.length > 0 && updateExisting !== \"true\") {\n  const parts = [];\n  parts.push(dbDup.length + \" alias(es) already exist and will be UPDATED with the imported values:\\n\" + dbDup.join(\"\\n\"));\n  if (toInsert.length > 0) parts.push(\"\\n\" + toInsert.length + \" new alias(es) will be imported.\");\n  if (dupInFile.length > 0) parts.push(\"\\n\" + dupInFile.length + \" duplicate row(s) within the file will be skipped.\");\n  return {\n    code: \"409\",\n    message: parts.join(\"\\n\") + \"\\n\\nUpdate the existing alias(es) and import the rest?\",\n    toInsert: [],\n    toUpdate: [],\n    inserted: \"0\",\n    updated: \"0\",\n    warning: \"\",\n    duplicates: dbDup.join(\"; \"),\n    hasInserts: false,\n    hasUpdates: false,\n  };\n}\n\n// Only update when the user confirmed. (When there were no existing dups, toUpdate is\n// already empty, so this only guards the theoretical no-confirm-with-dups path.)\nconst updates = updateExisting === \"true\" ? toUpdate : [];\n\nconst warnings = [];\nif (dupInFile.length > 0) warnings.push(\"Skipped \" + dupInFile.length + \" duplicate row(s) within the file.\");\nif (toInsert.length === 0 && updates.length === 0) warnings.push(\"Nothing to import.\");\n\nreturn {\n  code: \"200\",\n  message: \"\",\n  toInsert: toInsert,\n  toUpdate: updates,\n  inserted: String(toInsert.length),\n  updated: String(updates.length),\n  warning: warnings.join(\"\\n\"),\n  duplicates: \"\",\n  hasInserts: toInsert.length > 0,\n  hasUpdates: updates.length > 0,\n};\n"
        },
