        "script": {
          "type": "javascript",
          "code": "// Collect the distinct lookup keys the searches need:\n//  - orgNames : distinct Buyer + Seller organization names (dept_name)\n//  - itemCodes: distinct Buyer + Seller item codes (material_code)\n//  - uomNames : distinct Buyer + Seller UOM names (OPTIONAL columns; blank -> item base UOM)\n// import_data holds numeric-keyed data rows plus name/size/type meta keys.\nconst excelData = JSON.parse({{workflowparams:import_data}});\n\nconst orgNames = [];\nconst itemCodes = [];\nconst uomNames = [];\n\nconst push = (arr, v) => {\n  const s = v === undefined || v === null ? \"\" : String(v).trim();\n  if (s && arr.indexOf(s) === -1) arr.push(s);\n};\n\nObject.keys(excelData).forEach((k) => {\n  if (/^\\d+$/.test(k)) {\n    const row = excelData[k] || {};\n    push(orgNames, row[\"Buyer Organization\"]);\n    push(orgNames, row[\"Seller Organization\"]);\n    push(itemCodes, row[\"Buyer Item Code\"]);\n    push(itemCodes, row[\"Seller Item Code\"]);\n    push(uomNames, row[\"Buyer Item UOM\"]);\n    push(uomNames, row[\"Seller Item UOM\"]);\n  }\n});\n\n// Never feed an empty array into an `equalAny` filter; a \"0\" sentinel matches nothing.\nif (orgNames.length === 0) orgNames.push(\"0\");\nif (itemCodes.length === 0) itemCodes.push(\"0\");\nif (uomNames.length === 0) uomNames.push(\"0\");\n\nreturn { orgNames: orgNames, itemCodes: itemCodes, uomNames: uomNames };\n"
