    {
      "id": "code_node_8MJPH5aT",
      "type": "code-node",
      "data": {
        "language": "javascript",
        "code": "",
        "timeout": 30000,
        "title": "Map Picking Data",
        "isValidator": true,
        "nodeName": "Map Picking Data",
        "name": "Map Picking Data",
        "script": {
          "type": "javascript",
          "code": "const mapLineItem = (toData) => {\n  let tablePickingItems = [];\n  const pickingItemGroups = new Map();\n\n  for (const item of toData.table_to) {\n    if (!item.material_id || !item.temp_qty_data) continue;\n    if (item.picking_status === 'Completed') continue;\n\n    let tempArr = [];\n    try { tempArr = JSON.parse(item.temp_qty_data); } catch (e) { tempArr = []; }\n    let pickedArr = [];\n    try {\n      pickedArr = item.picked_temp_qty_data ? JSON.parse(item.picked_temp_qty_data) : [];\n    } catch (e) { pickedArr = []; }\n\n    const keyOf = (e) =>\n      (e.location_id || 'no-loc') + '_' +\n      (e.batch_id || 'no-batch') + '_' +\n      (e.handling_unit_id || 'no-hu');\n\n    // Sum already-picked qty per (location, batch, HU)\n    const pickedByKey = new Map();\n    for (const p of pickedArr) {\n      const k = keyOf(p);\n      pickedByKey.set(k, (pickedByKey.get(k) || 0) + parseFloat(p.to_quantity || 0));\n    }\n\n    for (const tempItem of tempArr) {\n      const used = pickedByKey.get(keyOf(tempItem)) || 0;\n      const remainingQty = parseFloat(tempItem.to_quantity || 0) - used;\n      if (remainingQty <= 0) continue;\n\n      const materialId = String(tempItem.material_id) || String(item.material_id);\n      const groupKey = `${item.id}_${materialId}_${\n        tempItem.batch_id || \"no-batch\"\n      }_${tempItem.location_id}`;\n\n      if (!pickingItemGroups.has(groupKey)) {\n        pickingItemGroups.set(groupKey, {\n          item_code: String(materialId),\n          item_name: item.material_name,\n          item_desc: item.to_material_desc || \"\",\n          more_desc: item.more_desc || \"\",\n          batch_no: tempItem.batch_id ? String(tempItem.batch_id) : null,\n          qty_to_pick: 0,\n          item_uom: String(item.to_order_uom_id),\n          picking_uom: String(item.to_order_uom_id),\n          source_bin: String(tempItem.location_id),\n          pending_process_qty: 0,\n          line_status: \"Open\",\n          so_no: item.line_so_no,\n          so_id: String(item.line_so_id),\n          so_line_id: String(item.so_line_item_id),\n          to_id: String(toData.id),\n          to_line_id: String(item.id),\n          serial_numbers: [],\n          is_serialized_item: 0,\n        });\n      }\n\n      const group = pickingItemGroups.get(groupKey);\n      group.qty_to_pick += remainingQty;\n      group.pending_process_qty += remainingQty;\n\n      if (tempItem.serial_number) {\n        group.serial_numbers.push(String(tempItem.serial_number));\n        group.is_serialized_item = 1;\n      }\n    }\n  }\n\n  for (const group of pickingItemGroups.values()) {\n    if (group.serial_numbers.length > 0) {\n      group.serial_numbers = group.serial_numbers.join(\", \");\n    } else {\n      delete group.serial_numbers;\n    }\n    tablePickingItems.push({ ...group });\n  }\n\n  return tablePickingItems;\n};\n\nconst mapToPickingData = (\n  pickingLineItemPromises,\n  toIDs,\n  soNos,\n  toCustomers,\n  plantID\n) => {\n  return {\n    so_no: soNos,\n    to_no: toIDs,\n    ref_doc_type: \"Picking Plan\",\n    table_picking_items: pickingLineItemPromises,\n    customer_id: toCustomers,\n    plant_id: plantID,\n  };\n};\n\nlet toData = {{node:search_node_zLieZ0R4.data.data}};\ntoData = toData.map((item) => ({\n  ...item,\n  table_to: item.table_to.filter((toItem) => toItem.picking_status !== 'Completed')\n}));\n\nconst toIDs = toData.map((to) => String(to.id));\nconst soNos = [\n  ...new Set(toData.flatMap((to) => to.so_no.split(', ')))\n].join(', ');\nconst toCustomers = [...new Set(toData.map((to) => String(to.customer_name)))];\nconst plantID = {{workflowparams:plant_id}};\nlet pickingLineItemPromises = [];\n\nfor (const to of toData) {\n  const lineItemPromise = mapLineItem(to);\n  pickingLineItemPromises.push(...lineItemPromise);\n}\n\nconst pickingData = mapToPickingData(pickingLineItemPromises, toIDs, soNos, toCustomers, plantID);\n\nreturn pickingData;\n"
        },
